---
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Aplicacion de cotizaciones para Confecciones Jotas.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="app-background" />
    <header class="sticky top-0 z-40 border-b border-border/80 bg-background/90 backdrop-blur-sm">
      <div class="mx-auto flex h-20 w-full max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <a href="/" class="flex items-center gap-3">
          <img src="/assets/logo.svg" alt="Confecciones Jotas" class="h-11 w-auto" />
          <div class="space-y-0.5">
            <p class="text-[0.78rem] font-semibold tracking-[0.2em] text-primary">CONFECCIONES JOTAS</p>
            <p class="text-xs tracking-wide text-muted-foreground">Gestor de Cotizaciones</p>
          </div>
        </a>

        <a
          href="/cotizaciones/nueva"
          class="inline-flex h-10 items-center justify-center rounded-sm border border-primary bg-primary px-4 text-sm font-semibold tracking-[0.03em] text-primary-foreground shadow-sm transition-colors hover:bg-primary/90"
        >
          Nueva cotizacion
        </a>
      </div>
    </header>

    <main class="mx-auto w-full max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>
  </body>
</html>
