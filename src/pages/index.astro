---
import { ListaCotizaciones } from '@/components/ListaCotizaciones';
import AppLayout from '@/layouts/AppLayout.astro';
import { listCotizaciones } from '@/lib/cotizaciones/repository';
import type { CotizacionListItem } from '@/lib/cotizaciones/types';
import { getSupabaseServerClient } from '@/lib/supabase/server';

let cotizaciones: CotizacionListItem[] = [];
let loadError: string | null = null;

try {
  const supabase = getSupabaseServerClient();
  cotizaciones = await listCotizaciones(supabase, 100);
} catch (error) {
  loadError = error instanceof Error ? error.message : 'No fue posible cargar datos.';
}
---

<AppLayout title="Cotizaciones | Confecciones Jotas">
  {loadError && (
    <div class="mb-4 rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-700">
      {loadError}
    </div>
  )}

  <ListaCotizaciones client:load initialCotizaciones={cotizaciones} />
</AppLayout>
